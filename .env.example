# Copy this file to .env, then replace the example with your BotFather token.
# Never share or commit your real token.
TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token
BOT_TOKEN=replace_with_your_telegram_bot_token

# Local/staging/production safety.
# Railway is production. Local Mac is test-only.
# Keep false unless Railway polling is paused/stopped.
LOCAL_BOT_ALLOWED=false
APP_VERSION=BETGPTAI v2.0

# API key from https://the-odds-api.com/.
ODDS_API_KEY=replace_with_your_odds_api_key

# Optional baseball enrichment key from https://highlightly.net/.
HIGHLIGHTLY_API_KEY=replace_with_your_highlightly_api_key

# API key from the OpenAI developer platform.
OPENAI_API_KEY=replace_with_your_openai_api_key

# BETGPTAI Anime Edition v7.0 image generation.
# false = /mlb_images sends and saves prompts only.
# true = /mlb_images sends prompts, generates owner-only preview images,
#        and saves them to generated_cards/YYYY-MM-DD/.
IMAGE_GENERATION_ENABLED=false
OPENAI_IMAGE_MODEL=gpt-image-1
# gpt-image-1 supports portrait sizes such as 1024x1536. The prompts request
# a 1080x1920 vertical card; change this only if your model supports it.
OPENAI_IMAGE_SIZE=1024x1536

# Optional second-opinion analysis key from Anthropic.
ANTHROPIC_API_KEY=replace_with_your_anthropic_api_key

# Optional Claude model override.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional free soccer schedule/results key from https://www.football-data.org/.
FOOTBALL_DATA_KEY=replace_with_your_football_data_key
FOOTBALL_DATA_API_KEY=replace_with_your_football_data_key

# Primary soccer data key from API-Football / API-Sports.
API_FOOTBALL_KEY=replace_with_your_api_football_key

# Emergency World Cup schedule fallback.
# When true, /soccer uses the built-in World Cup fallback schedule before
# returning an empty card.
WORLD_CUP_MODE=true

# Optional API-Sports Baseball key. Leave blank to reuse API_FOOTBALL_KEY.
# Disabled by default because free plans may not support the current MLB season.
API_SPORTS_BASEBALL_ENABLED=false
API_SPORTS_KEY=

# Optional soccer/baseball metadata provider from https://www.thesportsdb.com/.
# Used only for schedules, standings, logos, badges, stadiums, artwork, and TV metadata.
THESPORTSDB_ENABLED=false
THESPORTSDB_API_KEY=123
THE_SPORTS_DB_API_KEY=123

# Optional soccer enrichment providers. Disabled by default.
CLUB_ELO_ENABLED=false
UNDERSTAT_ENABLED=false

# Optional Google/SerpApi backup for sports news, standings, and context.
# Leave blank if you do not use SerpApi.
SERPAPI_KEY=

# Optional: change the OpenAI model without editing Python code.
OPENAI_MODEL=gpt-5.5

# Telegram user ID allowed to use private administration commands.
MY_TELEGRAM_ID=594425739

# Telegram destinations used by owner publishing and /test_channels.
# Numeric channel/supergroup IDs may be written with or without the leading -.
FREE_CHANNEL_ID=-1001234567890
VIP_CHANNEL_ID=-1001234567891
COMMUNITY_GROUP_ID=-1001234567892

# How often the game-aware scheduler refreshes official schedules (seconds).
SCHEDULER_POLL_SECONDS=120

# Official scheduler timezone. Railway server timezone should not control cards.
APP_TIMEZONE=America/New_York
TZ=America/New_York
DATA_DIR=/data

# Safety switch for automated public posting.
# false = never post automatically.
# true = allow the T-43 job to post after quality gates pass.
AUTO_POST_ENABLED=false
AI_LEARNING_AUTO_APPLY=true
